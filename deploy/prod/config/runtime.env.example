# GitHub Environment Secret PRODUCTION_RUNTIME_ENV에 저장할 dotenv 예시입니다.
# 실제 값, 비밀번호, 토큰, Firebase JSON은 이 파일에 넣지 않습니다.

APP_ENV=prod
DATABASE_URL=postgresql+asyncpg://<user>:<url-encoded-password>@<managed-db-host>:5432/<database>

JWT_SECRET_KEY=<openssl-random-value>
JWT_ALGORITHM=HS256
JWT_ISSUER=boat-backend
JWT_AUDIENCE=boat-api
ACCESS_TOKEN_EXPIRES_MINUTES=60
REFRESH_TOKEN_EXPIRES_DAYS=30
REFRESH_TOKEN_PEPPER=<openssl-random-value>
PROMOTION_BENEFICIARY_HMAC_SECRET=<openssl-random-value>

OPENROUTER_API_KEY=<key>
OPENROUTER_MODEL=<model-id>

FILE_STORAGE_BACKEND=s3
S3_BUCKET=<private-bucket-name>
S3_REGION=ap-northeast-2
S3_ENDPOINT_URL=

FIREBASE_PROJECT_ID=<firebase-project-id>
FIREBASE_CHECK_REVOKED=true

PUSH_SEND_ENABLED=true
PUSH_TOKEN_STALE_DAYS=60
OUTBOX_POLLER_ENABLED=true

# instance resource access를 사용하므로 정적 S3 access key는 넣지 않습니다.
# FIREBASE_CREDENTIALS_PATH는 backend 컨테이너에만 Compose가 주입합니다.
